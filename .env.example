# disclosure_anchor service environment template.
#
# Keep real credentials out of repo files. Put local secrets in your shell,
# Keychain, or a private env file outside this checkout.

DISCLOSURE_DATA_ROOT=/Volumes/AgentSSD/agent_system/services/disclosure_anchor
DISCLOSURE_SHARED_ROOT=/Volumes/AgentSSD/agent_system/shared
DISCLOSURE_RUNTIME_ROOT=/Volumes/AgentSSD/agent_system/services/disclosure_anchor/runtime

# Use a private password/env override for local development. Do not commit it.
DATABASE_URL=postgresql+psycopg://disclosure_anchor:<set-in-private-env>@127.0.0.1:55432/disclosure_anchor
DISCLOSURE_ADMIN_DATABASE_URL=postgresql+psycopg://disclosure_anchor:<set-in-private-env>@127.0.0.1:55432/postgres
DISCLOSURE_MIGRATION_DATABASE_URL=postgresql+psycopg://disclosure_anchor:<set-in-private-env>@127.0.0.1:55432/disclosure_anchor

DISCLOSURE_PGDATA=/Volumes/AgentSSD/agent_system/postgres/pg18-main
DISCLOSURE_PGSOCKET_DIR=/Volumes/AgentSSD/agent_system/postgres/sockets
DISCLOSURE_PGLOG=/Volumes/AgentSSD/agent_system/postgres/logs/disclosure-anchor-pg18.log

MINERU_MODEL_CACHE=/Volumes/AgentSSD/agent_system/shared/model_cache/mineru
HF_HOME=/Volumes/AgentSSD/agent_system/shared/model_cache/huggingface
MODELSCOPE_CACHE=/Volumes/AgentSSD/agent_system/shared/model_cache/modelscope

CNINFO_ACCESS_KEY=<set-in-private-env>
CNINFO_ACCESS_SECRET=<set-in-private-env>
CNINFO_ACCESS_TOKEN=<optional-private-env>
