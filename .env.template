# MCP environment variable template.
#
# Copy the variables you need into your shell profile or private env file.
# Keep real credentials out of repo files.

# Context7 MCP (optional — the server runs keyless without it, just lower rate limits)
CONTEXT7_API_KEY=<set_in_private_env>

# Alpaca (not used by the active MCP set; kept for future US-market work)
ALPACA_API_KEY=<set_in_private_env>
ALPACA_SECRET_KEY=<set_in_private_env>
ALPACA_PAPER_TRADE=True

# GitHub
GITHUB_PERSONAL_ACCESS_TOKEN=<set_in_private_env>
GITHUB_HOST=github.com

# Optional MCP keys (only if you enable these Tier-2 servers; see docs/MCP_SETUP_GUIDE.md)
FIRECRAWL_API_KEY=<set_in_private_env>
TAVILY_API_KEY=<set_in_private_env>

# Proxy settings, if needed
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost
http_proxy=
https_proxy=
no_proxy=127.0.0.1,localhost
