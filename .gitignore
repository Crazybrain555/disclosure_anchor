# Codex reads global config from ~/.codex/config.toml AND this repo-local, project-scoped
# .codex/config.toml (trusted projects, deep-merged over global). It holds the machine-specific
# dbhub server (project ledger DSN), so it stays gitignored like .mcp.json.
.codex/config.toml
dbhub.toml

