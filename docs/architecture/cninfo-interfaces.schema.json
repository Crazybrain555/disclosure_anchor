{
  "_about": "CNINFO WebAPI 第一阶段 4 接口的机器可读契约。供 client / router / 同步任务直接 import。",
  "see_also": {
    "human_doc": "cninfo-webapi-usage-reference.md（人读说明，配合本文件看）",
    "verification": "cninfo-webapi-verification.md（实测记录）",
    "announcement_categories": "cninfo-announcement-categories.json（公告类型全量 2135 条可选值，F006V 翻译用）",
    "securities_universe": "cninfo-securities.json（SECCODE/证券 全市场 7274 条清单）"
  },
  "meta": {
    "source": "https://webapi.cninfo.com.cn/#/apiDoc",
    "verified_date": "2026-06-15",
    "verified_method": "对每个接口实发 API 调用确认参数与行为（探针股票 300066）",
    "phase": 1
  },
  "auth": {
    "token_endpoint": "https://webapi.cninfo.com.cn/api-cloud-platform/oauth2/token",
    "token_method": "POST",
    "token_body": {
      "grant_type": "client_credentials",
      "client_id": "${CNINFO_ACCESS_KEY}",
      "client_secret": "${CNINFO_ACCESS_SECRET}"
    },
    "credentials_env": [
      "CNINFO_ACCESS_KEY",
      "CNINFO_ACCESS_SECRET",
      "CNINFO_ACCESS_TOKEN"
    ],
    "access_token_param": {
      "name": "access_token",
      "location": "query"
    },
    "token_ttl_seconds_observed": [
      2685,
      2985,
      3599
    ],
    "notes": [
      "凭证只从环境变量/.env 读取，不入库不入仓",
      "token 过期 405 / 无效 404，过期后用 key/secret 重换"
    ]
  },
  "result_envelope": {
    "resultcode": "int — 业务状态码，成功为 200",
    "resultmsg": "string",
    "total": "int — 命中总数（不受 @limit 影响）",
    "count": "int — 本次返回条数",
    "records": "array",
    "success_rule": "以 resultcode==200 为准，不要只看 HTTP status"
  },
  "common_query_params": [
    {
      "name": "format",
      "cn": "结果集格式",
      "type": "string",
      "required": false,
      "enum": [
        "xml",
        "json",
        "csv",
        "dbf"
      ],
      "default": "json",
      "example": "json",
      "note": "本服务默认 json"
    },
    {
      "name": "@column",
      "cn": "结果列选择",
      "type": "string",
      "required": false,
      "example": "SECCODE,SECNAME,F001D",
      "note": "多列逗号分隔"
    },
    {
      "name": "@limit",
      "cn": "结果条数限制",
      "type": "int",
      "required": false,
      "example": 100,
      "note": "截断本次返回条数；实测不改变 total"
    },
    {
      "name": "@orderby",
      "cn": "结果集排序",
      "type": "string",
      "required": false,
      "example": "F001D:desc",
      "note": "如 id:desc / id:asc"
    }
  ],
  "error_codes": {
    "-1": "系统繁忙（重试）",
    "200": "success",
    "401": "未经授权的访问",
    "402": "不合法的参数 / 缺少必须传输参数（无 scode 调 p_stock2100 实测返回此码）",
    "403": "脚本服务器异常",
    "404": "token 无效（重取）",
    "405": "token 过期（重取）",
    "406": "用户已被禁用",
    "407": "免费试用次数已用完",
    "408": "用户没有余额",
    "409": "验证权限错误",
    "410": "验证权限异常",
    "411": "获取用户信息失败",
    "412": "包时长已超期"
  },
